    "dexie-react-hooks": "^4.2.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "serwist": "^9.5.6",
    "shadcn": "^4.0.5",
