{
  "name": "fast-pos",
  "version": "2.0.0",
  "description": "Sistema de Punto de Venta offline first y ultrarrápido",
  "author": {
    "name": "Yetzapos",
    "email": "soporte@fastpos.com"
  },
  "private": true,
  "license": "UNLICENSED",
  "main": "electron-main.js",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "NODE_ENV=development electron .",
    "seed:paper": "NODE_ENV=development electron scripts/seed-paper.js",
    "dev:native": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron:dev\"",
    "reset": "rm -f fast-pos-dev.db && echo 'Base de datos eliminada. Reinicia la app para comenzar de cero.'",
    "build:ui": "next build --webpack",
    "build:electron": "echo 'No compilation needed for main.js yet'",
    "dist:mac": "export $(grep -v '^#' .env | xargs) && npm run build:ui && npm run build:electron && electron-builder -m",
    "dist:win": "export $(grep -v '^#' .env | xargs) && npm run build:ui && npm run build:electron && electron-builder -w",
    "dist:linux": "export $(grep -v '^#' .env | xargs) && npm run build:ui && npm run build:electron && electron-builder -l",
    "dist:all": "export $(grep -v '^#' .env | xargs) && npm run build:ui && npm run build:electron && electron-builder -mwl"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@serwist/next": "^9.5.6",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "dexie-export-import": "^4.1.4",
    "dexie-react-hooks": "^4.2.0",
    "driver.js": "^1.4.0",
    "electron-serve": "^1.1.0",
    "electron-updater": "^6.8.3",
    "googleapis": "^171.4.0",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "serwist": "^9.5.6",
    "shadcn": "^4.0.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.yetzapos.fastpos2",
    "productName": "FastPOS 2.0",
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.yetza.com/fastpos/"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "electron-main.js",
      "preload.js",
      "src/main/**/*",
      "public/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon-512x512.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "public/icon-512x512.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FastPOS 2.0",
      "uninstallDisplayName": "FastPOS 2.0"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64",
            "armv7l"
          ]
        }
      ],
      "category": "Office",
      "icon": "public/icon-512x512.png"
    }
  }
}
